{
  "name": "stitch-compact-pomodoro",
  "version": "1.0.0",
  "description": "Compact Pomodoro Timer Widget",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.dorodoro.app",
    "productName": "DoroDoro",
    "win": {
      "target": "nsis",
      "icon": "img/icon_app.ico"
    },
    "nsis": {
      "oneClick": true,
      "installerIcon": "img/icon_app.ico",
      "uninstallerIcon": "img/icon_app.ico"
    },
    "files": [
      "main.js",
      "renderer/**/*",
      "img/**/*",
      "sounds/**/*"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "electron-builder"]
  }
}
